{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api",
      "destination": "https://us-central1-normatel-rh.cloudfunctions.net/api"
    },
    {
      "source": "/api/:path*",
      "destination": "https://us-central1-normatel-rh.cloudfunctions.net/api/:path*"
    }
  ]
}
